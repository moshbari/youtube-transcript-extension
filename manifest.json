{
  "manifest_version": 3,
  "name": "YT Transcript Scraper by Mosh Bari",
  "version": "3.1",
  "description": "YouTube transcript scraper by Mosh Bari (ZPresso LLC): single, batch, or by-name transcripts, plus Tella call follow-up.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "alarms",
    "offscreen",
    "identity"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrape Transcript",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pulltranscript.com/*",
        "https://www.pulltranscript.com/*",
        "https://devrant.99dfy.com/*",
        "https://tellatotube.up.railway.app/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://studio.youtube.com/*",
    "https://tellatotube.up.railway.app/*",
    "https://pulltranscript.com/*",
    "https://www.pulltranscript.com/*",
    "https://devrant.99dfy.com/*"
  ]
}