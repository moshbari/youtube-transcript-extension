{
  "manifest_version": 3,
  "name": "YT Transcript Scraper — ZPressoLLC",
  "version": "2.7",
  "description": "Scrape YouTube transcripts (single, batch, or by name) or run Tella calls: upload, transcript, follow-up. By ZPressoLLC.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "alarms",
    "offscreen",
    "identity"
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrape Transcript",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://pulltranscript.com/*",
        "https://www.pulltranscript.com/*",
        "https://devrant.99dfy.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://studio.youtube.com/*",
    "https://tellatotube.up.railway.app/*",
    "https://pulltranscript.com/*",
    "https://www.pulltranscript.com/*",
    "https://devrant.99dfy.com/*"
  ]
}
